  "components": {
    "schemas": {
      "AdmissibilityReport": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/ChecklistItem"
            },
            "type": "array",
            "title": "Items"
          },
          "status": {
            "$ref": "#/components/schemas/AdmissibilityStatus"
          },
          "requires_amendment": {
            "type": "boolean",
            "title": "Requires Amendment"
          }
        },
        "type": "object",
        "required": [
          "items",
          "status",
          "requires_amendment"
        ],
        "title": "AdmissibilityReport"
      },
      "AdmissibilityStatus": {
        "type": "string",
        "enum": [
          "GREEN",
          "YELLOW",
          "RED"
        ],
        "title": "AdmissibilityStatus"
      },
      "AnalysisListItem": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "filename": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Filename"
          },
          "verdict": {
            "type": "string",
            "title": "Verdict"
          },
          "rito": {
            "type": "string",
            "title": "Rito"
          },
          "admissibility_status": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Admissibility Status"
          },
          "has_injunction": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Has Injunction"
          },
          "review_decision": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Review Decision"
          },
          "review_comment": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Review Comment"
          }
        },
        "type": "object",
        "required": [
          "id",
          "created_at",
          "filename",
          "verdict",
          "rito",
          "admissibility_status",
          "has_injunction"
        ],
        "title": "AnalysisListItem",
        "description": "Item do histórico: o resumo + a revisão humana mais recente (se houver)."
      },
      "AnalysisResult": {
        "properties": {
          "rito": {
            "$ref": "#/components/schemas/Rito",
            "default": "CIVEL"
          },
          "forensics": {
            "$ref": "#/components/schemas/ForensicsReport"
          },
          "summary": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/PetitionSummary"
              },
              {
                "type": "null"
              }
            ]
          },
          "admissibility": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/AdmissibilityReport"
              },
              {
                "type": "null"
              }
            ]
          },
          "tpu_suggestions": {
            "anyOf": [
              {
                "items": {
                  "$ref": "#/components/schemas/TpuSuggestion"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tpu Suggestions"
          }
        },
        "type": "object",
        "required": [
          "forensics"
        ],
        "title": "AnalysisResult",
        "description": "Resultado consolidado da análise de uma petição.\n\nQuando `forensics.verdict == BLOCK`, `summary` e `admissibility` são None\n(o fluxo encerrou antes do LLM)."
      },
      "AnalyzeResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "result": {
            "$ref": "#/components/schemas/AnalysisResult"
          }
        },
        "type": "object",
        "required": [
          "id",
          "result"
        ],
        "title": "AnalyzeResponse"
      },
      "Anomaly": {
        "properties": {
          "type": {
            "$ref": "#/components/schemas/AnomalyType"
          },
          "severity": {
            "$ref": "#/components/schemas/Severity"
          },
          "detail": {
            "type": "string",
            "title": "Detail"
          },
          "page": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Page"
          },
          "evidence": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Evidence"
          }
        },
        "type": "object",
        "required": [
          "type",
          "severity",
          "detail"
        ],
        "title": "Anomaly",
        "description": "Uma evidência de manipulação encontrada no documento."
      },
      "AnomalyType": {
        "type": "string",
        "enum": [
          "WHITE_ON_WHITE",
          "TINY_FONT",
          "OFF_CROPBOX",
          "ZERO_WIDTH_UNICODE",
          "HIDDEN_OCG_LAYER",
          "ACTUALTEXT_DIVERGENCE",
          "SUSPICIOUS_METADATA",
          "INJECTION_KEYWORDS"
        ],
        "title": "AnomalyType",
        "description": "Vetores de manipulação mapeados na pesquisa (seção 2.3)."
      },
      "AuditEvent": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "analysis_id": {
            "type": "string",
            "title": "Analysis Id"
          },
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "user_email": {
            "type": "string",
            "title": "User Email"
          },
          "decision": {
            "$ref": "#/components/schemas/ReviewDecision"
          },
          "comment": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Comment"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "analysis_id",
          "user_id",
          "user_email",
          "decision",
          "created_at"
        ],
        "title": "AuditEvent"
      },
      "Body_analyze_v1_analyze_post": {
        "properties": {
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File",
            "description": "PDF ou DOCX da petição inicial"
          },
          "rito": {
            "$ref": "#/components/schemas/Rito",
            "description": "Rito processual (default cível)",
            "default": "CIVEL"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_analyze_v1_analyze_post"
      },
      "Body_login_v1_auth_login_post": {
        "properties": {
          "username": {
            "type": "string",
            "title": "Username"
          },
          "password": {
            "type": "string",
            "title": "Password"
          }
        },
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "title": "Body_login_v1_auth_login_post"
      },
