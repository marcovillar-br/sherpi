      "RiskVerdict": {
        "type": "string",
        "enum": [
          "PASS",
          "WARN",
          "BLOCK"
        ],
        "title": "RiskVerdict",
        "description": "Veredito do firewall de integridade documental.\n\nPASS  — documento íntegro, segue para análise cognitiva.\nWARN  — anomalias de baixo risco; segue, mas sinaliza ao revisor humano.\nBLOCK — manipulação grave (ex.: prompt injection); interrompe o fluxo\n        ANTES de qualquer chamada a LLM."
      },
      "Rito": {
        "type": "string",
        "enum": [
          "CIVEL",
          "TRABALHISTA"
        ],
        "title": "Rito",
        "description": "Rito processual que define quais regras de admissibilidade se aplicam.\n\nO firewall e a extração são agnósticos ao rito; o que varia é a\nadmissibilidade (e, futuramente, a taxonomia TPU). Ver ADR-0008.\n\nCIVEL        — CPC art. 319 (rito padrão do MVP).\nTRABALHISTA  — CLT art. 840 §1º (exige pedido líquido).\n\nCresce por demanda (PREVIDENCIARIO, FISCAL, …) sem tocar nos ritos existentes."
      },
