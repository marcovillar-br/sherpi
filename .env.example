# Copie para .env.prod e preencha os segredos antes de subir em produção.
# Nunca commitar .env.prod no repositório.

SHERPI_DB_PASSWORD=<senha-forte>
SHERPI_JWT_SECRET=<segredo-forte-minimo-32-chars>
SHERPI_SEED_USER_PASSWORD=<senha-do-usuario-inicial>
SHERPI_SEED_USER_EMAIL=gabinete@sherpi.local
SHERPI_SENTRY_DSN=  # opcional — deixe vazio para desabilitar
SHERPI_LOG_LEVEL=INFO
SHERPI_RETENTION_DAYS=90
