# Copie para `.env` e preencha. NUNCA commite o `.env` real (contém segredos).
# Todas as variáveis usam o prefixo SHERPI_.

# --- Ambiente ---
SHERPI_ENV=dev
SHERPI_LOG_LEVEL=INFO

# --- LLM (default: Gemini Flash) ---
SHERPI_LLM_BACKEND=gemini
SHERPI_LLM_MODEL=gemini-2.5-flash
SHERPI_LLM_API_KEY=sua-chave-gemini-aqui
# Para Maritaca Sabiá / OpenAI / Ollama, use:
#   SHERPI_LLM_BACKEND=openai_compat
#   SHERPI_LLM_BASE_URL=https://chat.maritaca.ai/api
#   SHERPI_LLM_MODEL=sabia-3
SHERPI_LLM_TIMEOUT_SECONDS=30
SHERPI_LLM_MAX_RETRIES=3
SHERPI_LLM_TEMPERATURE=0.0          # 0.0 = determinístico (recomendado p/ extração)
SHERPI_LLM_MAX_INPUT_TOKENS=200000  # guarda de custo: corta entradas acima deste limite

# --- LGPD ---
SHERPI_ANONYMIZE_BEFORE_LLM=true

# --- Firewall / upload ---
SHERPI_MAX_UPLOAD_MB=25
SHERPI_MAX_PDF_PAGES=300

# --- Persistência ---
SHERPI_DATABASE_URL=postgresql+psycopg://sherpi:sherpi@localhost:5432/sherpi
SHERPI_BLOB_STORAGE_DIR=./data/uploads

# --- Auth (gere um segredo forte: `openssl rand -hex 32`) ---
SHERPI_JWT_SECRET=troque-por-um-segredo-forte
SHERPI_JWT_EXPIRE_MINUTES=60
SHERPI_SEED_USER_EMAIL=gabinete@sherpi.local
SHERPI_SEED_USER_PASSWORD=defina-uma-senha-forte

# --- CORS ---
SHERPI_CORS_ORIGINS=["http://localhost:3000"]
